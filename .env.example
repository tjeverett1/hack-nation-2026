# Copy this to `.env` and fill in real values.  `.env` must NEVER be committed.
# Find these in Databricks:
#   * DATABRICKS_HOST       → the workspace URL (no path/fragment).
#   * DATABRICKS_TOKEN      → User Settings → Developer → Access Tokens → Generate.
#   * DATABRICKS_HTTP_PATH  → SQL Warehouses → <warehouse> → Connection details
#                             (only needed if you also use notebooks/databricks_io.py).
DATABRICKS_HOST=https://dbc-XXXXXXXX.cloud.databricks.com
DATABRICKS_TOKEN=dapi...
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxxxxxx
